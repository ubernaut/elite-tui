{
  "tasks": {
    "start": "deno run --allow-env --allow-read --allow-sys src/main.ts",
    "check": "deno check src/main.ts",
    "web:check": "deno check src/web.ts",
    "web:build": "rm -rf dist && mkdir -p dist && cp web/index.html dist/index.html && deno bundle --platform browser --minify src/web.ts -o dist/elite-tui.js",
    "fmt": "deno fmt src web"
  },
  "fmt": {
    "lineWidth": 120
  },
  "lock": false
}
